generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id @default(uuid())
  email               String               @unique
  createdAt           DateTime             @default(now())
  passwordHash        String? // null = passwordless account (invite/magic-link sign-in)
  role                UserRole             @default(USER)
  phone               String?              @unique
  loginTokens         LoginToken[]
  createdFamilyGraphs FamilyGraph[]        @relation("FamilyGraphCreatedBy")
  acceptedInvites     Invitation[]         @relation("AcceptedByInvitations")
  sentInvitations     Invitation[]         @relation("InviterInvitations")
  invitedMembers      Membership[]         @relation("MembershipInvitedBy")
  memberships         Membership[]
  passwordResetTokens PasswordResetToken[]
  claimedPerson       Person?              @relation("ClaimedPerson")
  people              Person[]             @relation("CreatedPeople")
  vouchesGiven        Vouch[]              @relation("VouchesGiven")
  vouchesReceived     Vouch[]              @relation("VouchesReceived")
}

// One-time login tokens: invite-acceptance session exchange and email magic
// links. Only the SHA-256 hash of a token is stored.
model LoginToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  userId    String
  purpose   String    @default("LOGIN")
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model FamilyGraph {
  id          String       @id @default(uuid())
  createdAt   DateTime     @default(now())
  name        String?
  createdById String
  updatedAt   DateTime     @default(now())
  createdBy   User         @relation("FamilyGraphCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  invitations Invitation[]
  memberships Membership[]
  people      Person[]
  vouches     Vouch[]

  @@index([createdById])
}

model Membership {
  id              String      @id @default(uuid())
  createdAt       DateTime    @default(now())
  userId          String
  familyGraphId   String
  role            GraphRole   @default(MEMBER)
  invitedByUserId String?
  updatedAt       DateTime    @default(now())
  familyGraph     FamilyGraph @relation(fields: [familyGraphId], references: [id], onDelete: Cascade)
  invitedBy       User?       @relation("MembershipInvitedBy", fields: [invitedByUserId], references: [id])
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, familyGraphId])
  @@index([familyGraphId])
  @@index([userId])
  @@index([invitedByUserId])
}

model Invitation {
  id               String           @id @default(uuid())
  createdAt        DateTime         @default(now())
  token            String           @unique
  email            String?
  status           InvitationStatus @default(PENDING)
  familyGraphId    String
  targetPersonId   String
  inviterUserId    String
  acceptedByUserId String?
  acceptedAt       DateTime?
  declinedAt       DateTime?
  expiresAt        DateTime?
  phone            String?
  acceptedBy       User?            @relation("AcceptedByInvitations", fields: [acceptedByUserId], references: [id])
  familyGraph      FamilyGraph      @relation(fields: [familyGraphId], references: [id], onDelete: Cascade)
  inviter          User             @relation("InviterInvitations", fields: [inviterUserId], references: [id], onDelete: Cascade)
  targetPerson     Person           @relation("PersonInvitations", fields: [targetPersonId], references: [id], onDelete: Cascade)

  @@index([familyGraphId])
  @@index([targetPersonId])
  @@index([inviterUserId])
  @@index([email])
  @@index([phone])
}

model Vouch {
  id              String      @id @default(uuid())
  createdAt       DateTime    @default(now())
  familyGraphId   String
  vouchedByUserId String
  vouchedUserId   String
  familyGraph     FamilyGraph @relation(fields: [familyGraphId], references: [id], onDelete: Cascade)
  vouchedBy       User        @relation("VouchesGiven", fields: [vouchedByUserId], references: [id], onDelete: Cascade)
  vouchedUser     User        @relation("VouchesReceived", fields: [vouchedUserId], references: [id], onDelete: Cascade)

  @@unique([familyGraphId, vouchedByUserId, vouchedUserId])
  @@index([familyGraphId])
  @@index([vouchedByUserId])
  @@index([vouchedUserId])
}

model Person {
  id              String        @id @default(uuid())
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  fullName        String
  bio             String?
  birthDate       DateTime?
  deathDate       DateTime?
  location        String?
  photoUrl        String?
  isPrivate       Boolean       @default(false)
  createdById     String
  claimedByUserId String?       @unique
  familyGraphId   String
  deletedAt       DateTime?
  deletedByUserId String?
  purgeAfter      DateTime?
  firstName       String?
  lastName        String?
  grewUpLocation  String?
  currentLocation String?
  proudOf         String?
  occupation      String?
  interests       String?
  isVerified      Boolean?      @default(false)
  gender          String?
  story           String?
  fieldVisibility Json? // per-field privacy for claimed profiles: { field: "family" | "private" }
  invitations     Invitation[]  @relation("PersonInvitations")
  parents         ParentChild[] @relation("ChildParents")
  children        ParentChild[] @relation("ParentChildren")
  claimedBy       User?         @relation("ClaimedPerson", fields: [claimedByUserId], references: [id])
  createdBy       User          @relation("CreatedPeople", fields: [createdById], references: [id], onDelete: Cascade)
  familyGraph     FamilyGraph   @relation(fields: [familyGraphId], references: [id], onDelete: Cascade)
  spousesA        Spouse[]      @relation("SpouseA")
  spousesB        Spouse[]      @relation("SpouseB")

  @@index([fullName])
  @@index([createdById])
  @@index([isPrivate])
  @@index([familyGraphId])
  @@index([familyGraphId, deletedAt])
  @@index([purgeAfter])
}

model ParentChild {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  parentId  String
  childId   String
  type      String? // biological | adopted | step | guardian (null = unspecified)
  child     Person   @relation("ChildParents", fields: [childId], references: [id], onDelete: Cascade)
  parent    Person   @relation("ParentChildren", fields: [parentId], references: [id], onDelete: Cascade)

  @@unique([parentId, childId])
  @@index([parentId])
  @@index([childId])
}

model Spouse {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  aId       String
  bId       String
  status    String? // married | partner | divorced | widowed (null = unspecified)
  startDate DateTime?
  endDate   DateTime?
  a         Person   @relation("SpouseA", fields: [aId], references: [id], onDelete: Cascade)
  b         Person   @relation("SpouseB", fields: [bId], references: [id], onDelete: Cascade)

  @@unique([aId, bId])
  @@index([aId])
  @@index([bId])
}

model Passcode {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code         String    @unique @db.VarChar(8)
  usedByUserId String?   @db.Uuid
  usedAt       DateTime? @db.Timestamp(6)
  createdAt    DateTime? @default(now()) @db.Timestamp(6)
}

// Audit trail: one row per mutation (person updates get one row per changed
// field). No foreign keys on purpose — log rows must survive deletion of the
// things they describe. String columns instead of enums to keep values open.
model ChangeLog {
  id             String   @id @default(uuid())
  familyGraphId  String
  actorUserId    String
  targetPersonId String?
  targetType     String // PERSON | PARENT_CHILD | SPOUSE | INVITATION | VOUCH
  targetId       String
  action         String // CREATE | UPDATE | DELETE | RESTORE
  field          String?
  oldValue       String?
  newValue       String?
  toldByPersonId String? // scribe attribution: whose knowledge this edit records
  createdAt      DateTime @default(now())

  @@index([familyGraphId, createdAt])
  @@index([targetPersonId])
}

enum GraphRole {
  FOUNDER
  TRUSTED
  MEMBER
  ADMIN
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
  REVOKED
}

enum UserRole {
  USER
  ADMIN
}


